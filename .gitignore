# Python bytecode
__pycache__/
*.py[cod]
*.pyo

# pytest
.pytest_cache/

# packaging / build
*.egg-info/
dist/
build/
.eggs/

# search checkpoints (large binary files, regenerated by --resume)
results/checkpoints/
*.pkl

# generated figures (regenerated by scripts/generate_figures.py)
figures/
paper_assets/figures/*
!paper_assets/figures/radii_vs_n.png
!paper_assets/figures/n14.png

# LaTeX build byproducts
paper_assets/*.aux
paper_assets/*.log
paper_assets/*.out
paper_assets/*.toc
paper_assets/*.synctex.gz
paper_assets/*.fls
paper_assets/*.fdb_latexmk
paper_assets/*.bbl
paper_assets/*.blg
